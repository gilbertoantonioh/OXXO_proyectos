	END IF;
END;


--TRIGGER ON_DELETE
DECLARE
	v_errors VARCHAR(500);
	v_retcode NUMBER;
	v_alert_id ALERT;
	v_alert_ret NUMBER;
BEGIN
	XXFA_SN_DATA_DETAILS_PKG.delete_row(:XXFA_SN_DATA_DETAILS.DATA_DETAIL_ID
			, v_errors, v_retcode);
	IF (v_retcode != 0) THEN
		v_alert_id := FIND_ALERT('ERROR_ALERT');
		SET_ALERT_PROPERTY(v_alert_id, ALERT_MESSAGE_TEXT, v_errors);
		v_alert_ret := SHOW_ALERT(v_alert_id);
		RAISE FORM_TRIGGER_FAILURE;
	END IF;
END;
