			, :XXFA_SN_FE_DATA_DETAILS.RCV_PO_HEADER_ID
			, :XXFA_SN_FE_DATA_DETAILS.POH_ORG_ID
			, :XXFA_SN_FE_DATA_DETAILS.AP_ORG_COMPANY_RFC
			, :XXFA_SN_FE_DATA_DETAILS.AP_ORG_COMPANY_NAME
