--TRIGGERS FOR PACKAGEXXFA_SN_FE_DATA_DETAILS_PKG


/*-----------------------------------------------------------------------------
 *----------------TRIGGERS FOR XxfaSnFeDataDetails---------------
 *-----------------------------------------------------------------------------*/


--TRIGGER ON_LOCK
DECLARE
	v_errors VARCHAR(500);
	v_retcode NUMBER;
	v_alert_id ALERT;
	v_alert_ret NUMBER;
BEGIN
	XXFA_SN_FE_DATA_DETAILS_PKG.lock_row(
			:XXFA_SN_FE_DATA_DETAILS.ROW_ID
			, :XXFA_SN_FE_DATA_DETAILS.FE_DATA_DETAIL_ID
			, :XXFA_SN_FE_DATA_DETAILS.RCV_INVOICE_NUM
			, :XXFA_SN_FE_DATA_DETAILS.RCV_PO_HEADER_ID
			, :XXFA_SN_FE_DATA_DETAILS.POH_ORG_ID
			, :XXFA_SN_FE_DATA_DETAILS.AP_ORG_COMPANY_RFC
			, :XXFA_SN_FE_DATA_DETAILS.AP_ORG_COMPANY_NAME
			, :XXFA_SN_FE_DATA_DETAILS.RCV_VENDOR_ID
			, :XXFA_SN_FE_DATA_DETAILS.ASU_VENDOR_NUMBER
			, :XXFA_SN_FE_DATA_DETAILS.ASU_VENDOR_NAME
			, :XXFA_SN_FE_DATA_DETAILS.RSL_ITEM_ID
			, :XXFA_SN_FE_DATA_DETAILS.MSI_ITEM_NUMBER
			, :XXFA_SN_FE_DATA_DETAILS.RCV_SHIPMENT_HEADER_ID
			, :XXFA_SN_FE_DATA_DETAILS.RCV_SHIPMENT_LINE_ID
			, :XXFA_SN_FE_DATA_DETAILS.RSL_ITEM_DESCRIPTION
			, :XXFA_SN_FE_DATA_DETAILS.RCV_QUANTITY
			, :XXFA_SN_FE_DATA_DETAILS.RCV_TRANSACTION_ID
			, :XXFA_SN_FE_DATA_DETAILS.RCV_PO_UNIT_PRICE
			, :XXFA_SN_FE_DATA_DETAILS.RCV_CURRENCY_CODE
			, :XXFA_SN_FE_DATA_DETAILS.RCV_CURRENCY_CONVERSION_RATE
			, :XXFA_SN_FE_DATA_DETAILS.LAST_UPDATE_LOGIN
			, v_errors, v_retcode);
	IF (v_retcode != 0) THEN
		v_alert_id := FIND_ALERT('ERROR_ALERT');
		SET_ALERT_PROPERTY(v_alert_id, ALERT_MESSAGE_TEXT, v_errors);
		v_alert_ret := SHOW_ALERT(v_alert_id);
		RAISE FORM_TRIGGER_FAILURE;
	END IF;
END;


