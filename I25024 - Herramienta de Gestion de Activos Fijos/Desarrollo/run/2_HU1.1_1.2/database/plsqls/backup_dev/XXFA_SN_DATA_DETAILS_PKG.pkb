			, FCB_ASSET_CATEG_FAKEY
			, ASSET_BADGEABLE
			, FAA_MANUFACTURER_NAME
			, FAA_MODEL_NUMBER
			, FAA_SERIAL_NUMBER
			, FAA_DESCRIPTION
			, FBK_DATE_PLACED_MM
			, FBK_DATE_PLACED_YYYY
			, FAA_PROPERTY_TYPE_CODE
