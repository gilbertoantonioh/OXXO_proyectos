				AND ((recinfo.RCV_INV_ORGANIZATION_ID = p_RCV_INV_ORGANIZATION_ID) OR (recinfo.RCV_INV_ORGANIZATION_ID IS NULL AND p_RCV_INV_ORGANIZATION_ID IS NULL))
				AND ((recinfo.MTL_INV_ORGANIZATION_CODE = p_MTL_INV_ORGANIZATION_CODE) OR (recinfo.MTL_INV_ORGANIZATION_CODE IS NULL AND p_MTL_INV_ORGANIZATION_CODE IS NULL))
				AND ((recinfo.POH_ORG_ID = p_POH_ORG_ID) OR (recinfo.POH_ORG_ID IS NULL AND p_POH_ORG_ID IS NULL))
				AND ((recinfo.HOU_ORG_CODE = p_HOU_ORG_CODE) OR (recinfo.HOU_ORG_CODE IS NULL AND p_HOU_ORG_CODE IS NULL))
				AND ((recinfo.FAA_ASSET_ID = p_FAA_ASSET_ID) OR (recinfo.FAA_ASSET_ID IS NULL AND p_FAA_ASSET_ID IS NULL))
				AND ((recinfo.FAA_ASSET_NUMBER = p_FAA_ASSET_NUMBER) OR (recinfo.FAA_ASSET_NUMBER IS NULL AND p_FAA_ASSET_NUMBER IS NULL))
				AND ((recinfo.FAA_TAG_NUMBER = p_FAA_TAG_NUMBER) OR (recinfo.FAA_TAG_NUMBER IS NULL AND p_FAA_TAG_NUMBER IS NULL))
				AND ((recinfo.FAA_ASSET_CATEGORY_ID = p_FAA_ASSET_CATEGORY_ID) OR (recinfo.FAA_ASSET_CATEGORY_ID IS NULL AND p_FAA_ASSET_CATEGORY_ID IS NULL))
				AND ((recinfo.FCB_ASSET_CATEG_SEG_CONCAT = p_FCB_ASSET_CATEG_SEG_CONCAT) OR (recinfo.FCB_ASSET_CATEG_SEG_CONCAT IS NULL AND p_FCB_ASSET_CATEG_SEG_CONCAT IS NULL))
				AND ((recinfo.FCB_ASSET_CATEG_ACCT = p_FCB_ASSET_CATEG_ACCT) OR (recinfo.FCB_ASSET_CATEG_ACCT IS NULL AND p_FCB_ASSET_CATEG_ACCT IS NULL))
				AND ((recinfo.FCB_ASSET_CATEG_SUBACCT = p_FCB_ASSET_CATEG_SUBACCT) OR (recinfo.FCB_ASSET_CATEG_SUBACCT IS NULL AND p_FCB_ASSET_CATEG_SUBACCT IS NULL))
				AND ((recinfo.FCB_ASSET_CATEG_FAM = p_FCB_ASSET_CATEG_FAM) OR (recinfo.FCB_ASSET_CATEG_FAM IS NULL AND p_FCB_ASSET_CATEG_FAM IS NULL))
				AND ((recinfo.FCB_ASSET_CATEG_FAKEY = p_FCB_ASSET_CATEG_FAKEY) OR (recinfo.FCB_ASSET_CATEG_FAKEY IS NULL AND p_FCB_ASSET_CATEG_FAKEY IS NULL))
				AND ((recinfo.ASSET_BADGEABLE = p_ASSET_BADGEABLE) OR (recinfo.ASSET_BADGEABLE IS NULL AND p_ASSET_BADGEABLE IS NULL))
				AND ((recinfo.FAA_MANUFACTURER_NAME = p_FAA_MANUFACTURER_NAME) OR (recinfo.FAA_MANUFACTURER_NAME IS NULL AND p_FAA_MANUFACTURER_NAME IS NULL))
				AND ((recinfo.FAA_MODEL_NUMBER = p_FAA_MODEL_NUMBER) OR (recinfo.FAA_MODEL_NUMBER IS NULL AND p_FAA_MODEL_NUMBER IS NULL))
				AND ((recinfo.FAA_SERIAL_NUMBER = p_FAA_SERIAL_NUMBER) OR (recinfo.FAA_SERIAL_NUMBER IS NULL AND p_FAA_SERIAL_NUMBER IS NULL))
				AND ((recinfo.FAA_DESCRIPTION = p_FAA_DESCRIPTION) OR (recinfo.FAA_DESCRIPTION IS NULL AND p_FAA_DESCRIPTION IS NULL))
				AND ((recinfo.FBK_DATE_PLACED_MM = p_FBK_DATE_PLACED_MM) OR (recinfo.FBK_DATE_PLACED_MM IS NULL AND p_FBK_DATE_PLACED_MM IS NULL))
				AND ((recinfo.FBK_DATE_PLACED_YYYY = p_FBK_DATE_PLACED_YYYY) OR (recinfo.FBK_DATE_PLACED_YYYY IS NULL AND p_FBK_DATE_PLACED_YYYY IS NULL))
				AND ((recinfo.FAA_PROPERTY_TYPE_CODE = p_FAA_PROPERTY_TYPE_CODE) OR (recinfo.FAA_PROPERTY_TYPE_CODE IS NULL AND p_FAA_PROPERTY_TYPE_CODE IS NULL))
				AND ((recinfo.PRL_REQUISITION_LINE_ID = p_PRL_REQUISITION_LINE_ID) OR (recinfo.PRL_REQUISITION_LINE_ID IS NULL AND p_PRL_REQUISITION_LINE_ID IS NULL))
				AND ((recinfo.PRL_ORACLE_CIA = p_PRL_ORACLE_CIA) OR (recinfo.PRL_ORACLE_CIA IS NULL AND p_PRL_ORACLE_CIA IS NULL))
				AND ((recinfo.PRL_ORACLE_EF = p_PRL_ORACLE_EF) OR (recinfo.PRL_ORACLE_EF IS NULL AND p_PRL_ORACLE_EF IS NULL))
				AND ((recinfo.PRL_RETEK_DISTRITO = p_PRL_RETEK_DISTRITO) OR (recinfo.PRL_RETEK_DISTRITO IS NULL AND p_PRL_RETEK_DISTRITO IS NULL))
				AND ((recinfo.PRL_ORACLE_CR = p_PRL_ORACLE_CR) OR (recinfo.PRL_ORACLE_CR IS NULL AND p_PRL_ORACLE_CR IS NULL))
				AND ((recinfo.PRL_ORACLE_CR_DESCR = p_PRL_ORACLE_CR_DESCR) OR (recinfo.PRL_ORACLE_CR_DESCR IS NULL AND p_PRL_ORACLE_CR_DESCR IS NULL))
				AND ((recinfo.PRL_ORACLE_CR_SUPERIOR = p_PRL_ORACLE_CR_SUPERIOR) OR (recinfo.PRL_ORACLE_CR_SUPERIOR IS NULL AND p_PRL_ORACLE_CR_SUPERIOR IS NULL))
				AND ((recinfo.PRL_ORACLE_CR_SUP_DESCR = p_PRL_ORACLE_CR_SUP_DESCR) OR (recinfo.PRL_ORACLE_CR_SUP_DESCR IS NULL AND p_PRL_ORACLE_CR_SUP_DESCR IS NULL))
				AND ((recinfo.OOH_HEADER_ID = p_OOH_HEADER_ID) OR (recinfo.OOH_HEADER_ID IS NULL AND p_OOH_HEADER_ID IS NULL))
				AND ((recinfo.OOH_ORDER_NUMBER = p_OOH_ORDER_NUMBER) OR (recinfo.OOH_ORDER_NUMBER IS NULL AND p_OOH_ORDER_NUMBER IS NULL))
				AND ((recinfo.WST_TRIP_ID = p_WST_TRIP_ID) OR (recinfo.WST_TRIP_ID IS NULL AND p_WST_TRIP_ID IS NULL))
				AND ((recinfo.WST_TRIP_NAME = p_WST_TRIP_NAME) OR (recinfo.WST_TRIP_NAME IS NULL AND p_WST_TRIP_NAME IS NULL))
				AND ((recinfo.MMT_TRANSACTION_ID = p_MMT_TRANSACTION_ID) OR (recinfo.MMT_TRANSACTION_ID IS NULL AND p_MMT_TRANSACTION_ID IS NULL))
				AND ((recinfo.SN_U_ESTATUS_ASSETS = p_SN_U_ESTATUS_ASSETS) OR (recinfo.SN_U_ESTATUS_ASSETS IS NULL AND p_SN_U_ESTATUS_ASSETS IS NULL))
				AND ((recinfo.SN_U_ESTATUS_CONTABLE = p_SN_U_ESTATUS_CONTABLE) OR (recinfo.SN_U_ESTATUS_CONTABLE IS NULL AND p_SN_U_ESTATUS_CONTABLE IS NULL))
				AND ((recinfo.SN_U_ESTATUS_FACTURA = p_SN_U_ESTATUS_FACTURA) OR (recinfo.SN_U_ESTATUS_FACTURA IS NULL AND p_SN_U_ESTATUS_FACTURA IS NULL))
				AND ((recinfo.SN_U_FOLIO_VALIDACION_FACTURA = p_SN_U_FOLIO_VALIDACION_FACTURA) OR (recinfo.SN_U_FOLIO_VALIDACION_FACTURA IS NULL AND p_SN_U_FOLIO_VALIDACION_FACTURA IS NULL))
				AND ((recinfo.SN_U_FOLIO_SALIDA = p_SN_U_FOLIO_SALIDA) OR (recinfo.SN_U_FOLIO_SALIDA IS NULL AND p_SN_U_FOLIO_SALIDA IS NULL))
				AND ((recinfo.SN_U_SUBTOTAL = p_SN_U_SUBTOTAL) OR (recinfo.SN_U_SUBTOTAL IS NULL AND p_SN_U_SUBTOTAL IS NULL))
				AND ((recinfo.SN_U_DESCUENTO = p_SN_U_DESCUENTO) OR (recinfo.SN_U_DESCUENTO IS NULL AND p_SN_U_DESCUENTO IS NULL))
				AND ((recinfo.SN_U_IMPUESTO = p_SN_U_IMPUESTO) OR (recinfo.SN_U_IMPUESTO IS NULL AND p_SN_U_IMPUESTO IS NULL))
				AND ((recinfo.SN_U_RETENCIONES = p_SN_U_RETENCIONES) OR (recinfo.SN_U_RETENCIONES IS NULL AND p_SN_U_RETENCIONES IS NULL))
				AND ((recinfo.SN_U_TOTAL = p_SN_U_TOTAL) OR (recinfo.SN_U_TOTAL IS NULL AND p_SN_U_TOTAL IS NULL))
				AND ((recinfo.SN_UUID_FOLIO_STAT = p_SN_UUID_FOLIO_STAT) OR (recinfo.SN_UUID_FOLIO_STAT IS NULL AND p_SN_UUID_FOLIO_STAT IS NULL))
				AND ((recinfo.SN_USO_CFDI = p_SN_USO_CFDI) OR (recinfo.SN_USO_CFDI IS NULL AND p_SN_USO_CFDI IS NULL))
				AND ((recinfo.SN_U_MONEDA = p_SN_U_MONEDA) OR (recinfo.SN_U_MONEDA IS NULL AND p_SN_U_MONEDA IS NULL))
				AND ((recinfo.SN_U_TIPO_CAMBIO = p_SN_U_TIPO_CAMBIO) OR (recinfo.SN_U_TIPO_CAMBIO IS NULL AND p_SN_U_TIPO_CAMBIO IS NULL))
				AND ((recinfo.SN_U_METODO_PAGO = p_SN_U_METODO_PAGO) OR (recinfo.SN_U_METODO_PAGO IS NULL AND p_SN_U_METODO_PAGO IS NULL))
				AND ((recinfo.SN_U_FORMA_PAGO = p_SN_U_FORMA_PAGO) OR (recinfo.SN_U_FORMA_PAGO IS NULL AND p_SN_U_FORMA_PAGO IS NULL))
				AND ((recinfo.SN_U_REGIMENT_FISCAL = p_SN_U_REGIMENT_FISCAL) OR (recinfo.SN_U_REGIMENT_FISCAL IS NULL AND p_SN_U_REGIMENT_FISCAL IS NULL))
				AND ((recinfo.LAST_UPDATE_LOGIN = p_LAST_UPDATE_LOGIN) OR (recinfo.LAST_UPDATE_LOGIN IS NULL AND p_LAST_UPDATE_LOGIN IS NULL)))) THEN
			x_retcode := 2;
			x_errors := 'THE RECORD WITH ROWID = ' || p_rowid || ' IN TABLE XXFA_SN_DATA_DETAILS HAS CHANGED.';
		END IF;
		CLOSE c;
	EXCEPTION
		WHEN OTHERS THEN
			x_retcode := 2;
			x_errors := SQLERRM;
	END lock_row;


