			, PRL_ORACLE_CIA
			, PRL_ORACLE_EF
			, PRL_RETEK_DISTRITO
			, PRL_ORACLE_CR
			, PRL_ORACLE_CR_DESCR
			, PRL_ORACLE_CR_SUPERIOR
			, PRL_ORACLE_CR_SUP_DESCR
