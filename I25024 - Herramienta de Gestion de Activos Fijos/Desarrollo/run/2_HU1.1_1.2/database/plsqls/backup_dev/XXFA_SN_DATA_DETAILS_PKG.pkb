			, SN_U_REGIMENT_FISCAL = DECODE(p_SN_U_REGIMENT_FISCAL, FT_COMMON.G_MISS_VARCHAR2, SN_U_REGIMENT_FISCAL, p_SN_U_REGIMENT_FISCAL)
			, LAST_UPDATE_LOGIN = DECODE(p_LAST_UPDATE_LOGIN, FT_COMMON.G_MISS_NUMBER, LAST_UPDATE_LOGIN, p_LAST_UPDATE_LOGIN)
			, LAST_UPDATE_DATE = SYSDATE
			, LAST_UPDATED_BY = USER
		WHERE DATA_DETAIL_ID = p_DATA_DETAIL_ID;
		x_retcode := 0;
		COMMIT;
	EXCEPTION
		WHEN OTHERS THEN
			x_errors := SQLERRM;
			x_retcode := 2;
	END update_row;


