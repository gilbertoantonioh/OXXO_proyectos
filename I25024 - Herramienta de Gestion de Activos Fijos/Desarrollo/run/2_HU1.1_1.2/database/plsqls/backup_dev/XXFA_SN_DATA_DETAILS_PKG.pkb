			, p_FCB_ASSET_CATEG_ACCT IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_FCB_ASSET_CATEG_SUBACCT IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_FCB_ASSET_CATEG_FAM IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_FCB_ASSET_CATEG_FAKEY IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_ASSET_BADGEABLE IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_FAA_MANUFACTURER_NAME IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_FAA_MODEL_NUMBER IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_FAA_SERIAL_NUMBER IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_FAA_DESCRIPTION IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_FBK_DATE_PLACED_MM IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_FBK_DATE_PLACED_YYYY IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_FAA_PROPERTY_TYPE_CODE IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_PRL_REQUISITION_LINE_ID IN NUMBER DEFAULT FT_COMMON.G_MISS_NUMBER
			, p_PRL_ORACLE_CIA IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_PRL_ORACLE_EF IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_PRL_RETEK_DISTRITO IN NUMBER DEFAULT FT_COMMON.G_MISS_NUMBER
			, p_PRL_ORACLE_CR IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_PRL_ORACLE_CR_DESCR IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_PRL_ORACLE_CR_SUPERIOR IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_PRL_ORACLE_CR_SUP_DESCR IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_OOH_HEADER_ID IN NUMBER DEFAULT FT_COMMON.G_MISS_NUMBER
			, p_OOH_ORDER_NUMBER IN NUMBER DEFAULT FT_COMMON.G_MISS_NUMBER
			, p_WST_TRIP_ID IN NUMBER DEFAULT FT_COMMON.G_MISS_NUMBER
			, p_WST_TRIP_NAME IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_MMT_TRANSACTION_ID IN NUMBER DEFAULT FT_COMMON.G_MISS_NUMBER
			, p_SN_U_ESTATUS_ASSETS IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_SN_U_ESTATUS_CONTABLE IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_SN_U_ESTATUS_FACTURA IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_SN_U_FOLIO_VALIDACION_FACTURA IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_SN_U_FOLIO_SALIDA IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_SN_U_SUBTOTAL IN NUMBER DEFAULT FT_COMMON.G_MISS_NUMBER
			, p_SN_U_DESCUENTO IN NUMBER DEFAULT FT_COMMON.G_MISS_NUMBER
			, p_SN_U_IMPUESTO IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_SN_U_RETENCIONES IN NUMBER DEFAULT FT_COMMON.G_MISS_NUMBER
			, p_SN_U_TOTAL IN NUMBER DEFAULT FT_COMMON.G_MISS_NUMBER
			, p_SN_UUID_FOLIO_STAT IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_SN_USO_CFDI IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_SN_U_MONEDA IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_SN_U_TIPO_CAMBIO IN NUMBER DEFAULT FT_COMMON.G_MISS_NUMBER
			, p_SN_U_METODO_PAGO IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_SN_U_FORMA_PAGO IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_SN_U_REGIMENT_FISCAL IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_LAST_UPDATE_LOGIN IN NUMBER DEFAULT FT_COMMON.G_MISS_NUMBER
			, x_errors IN OUT VARCHAR2, x_retcode IN OUT NUMBER) IS
		
	BEGIN
		x_errors := '';
		UPDATE XXFA_SN_DATA_DETAILS SET DATA_DETAIL_ID = DECODE(p_DATA_DETAIL_ID, FT_COMMON.G_MISS_NUMBER, DATA_DETAIL_ID, p_DATA_DETAIL_ID)
			, RCV_TRANSACTION_ID = DECODE(p_RCV_TRANSACTION_ID, FT_COMMON.G_MISS_NUMBER, RCV_TRANSACTION_ID, p_RCV_TRANSACTION_ID)
			, RCV_DESTINATION_TYPE_CODE = DECODE(p_RCV_DESTINATION_TYPE_CODE, FT_COMMON.G_MISS_VARCHAR2, RCV_DESTINATION_TYPE_CODE, p_RCV_DESTINATION_TYPE_CODE)
			, RCV_TRANSACTION_DATE = DECODE(p_RCV_TRANSACTION_DATE, FT_COMMON.G_MISS_DATE, RCV_TRANSACTION_DATE, p_RCV_TRANSACTION_DATE)
			, RCV_PRIMARY_UNIT_OF_MEASURE = DECODE(p_RCV_PRIMARY_UNIT_OF_MEASURE, FT_COMMON.G_MISS_VARCHAR2, RCV_PRIMARY_UNIT_OF_MEASURE, p_RCV_PRIMARY_UNIT_OF_MEASURE)
			, RCV_SHIPMENT_HEADER_ID = DECODE(p_RCV_SHIPMENT_HEADER_ID, FT_COMMON.G_MISS_NUMBER, RCV_SHIPMENT_HEADER_ID, p_RCV_SHIPMENT_HEADER_ID)
			, RSH_RECEIPT_NUM = DECODE(p_RSH_RECEIPT_NUM, FT_COMMON.G_MISS_VARCHAR2, RSH_RECEIPT_NUM, p_RSH_RECEIPT_NUM)
			, RCV_SHIPMENT_LINE_ID = DECODE(p_RCV_SHIPMENT_LINE_ID, FT_COMMON.G_MISS_NUMBER, RCV_SHIPMENT_LINE_ID, p_RCV_SHIPMENT_LINE_ID)
			, RSL_SHIPMENT_LINE_NUM = DECODE(p_RSL_SHIPMENT_LINE_NUM, FT_COMMON.G_MISS_NUMBER, RSL_SHIPMENT_LINE_NUM, p_RSL_SHIPMENT_LINE_NUM)
			, RSL_ITEM_ID = DECODE(p_RSL_ITEM_ID, FT_COMMON.G_MISS_NUMBER, RSL_ITEM_ID, p_RSL_ITEM_ID)
			, MSI_ITEM_NUMBER = DECODE(p_MSI_ITEM_NUMBER, FT_COMMON.G_MISS_VARCHAR2, MSI_ITEM_NUMBER, p_MSI_ITEM_NUMBER)
			, MSI_USE_TYPE = DECODE(p_MSI_USE_TYPE, FT_COMMON.G_MISS_VARCHAR2, MSI_USE_TYPE, p_MSI_USE_TYPE)
			, RSL_ITEM_DESCRIPTION = DECODE(p_RSL_ITEM_DESCRIPTION, FT_COMMON.G_MISS_VARCHAR2, RSL_ITEM_DESCRIPTION, p_RSL_ITEM_DESCRIPTION)
			, MIC_ITEM_CATEGORY_ID = DECODE(p_MIC_ITEM_CATEGORY_ID, FT_COMMON.G_MISS_NUMBER, MIC_ITEM_CATEGORY_ID, p_MIC_ITEM_CATEGORY_ID)
			, MIC_ITEM_CATEG_FAM = DECODE(p_MIC_ITEM_CATEG_FAM, FT_COMMON.G_MISS_VARCHAR2, MIC_ITEM_CATEG_FAM, p_MIC_ITEM_CATEG_FAM)
			, MIC_ITEM_CATEG_SUBFAM = DECODE(p_MIC_ITEM_CATEG_SUBFAM, FT_COMMON.G_MISS_VARCHAR2, MIC_ITEM_CATEG_SUBFAM, p_MIC_ITEM_CATEG_SUBFAM)
			, MSI_KIT_TYPE = DECODE(p_MSI_KIT_TYPE, FT_COMMON.G_MISS_VARCHAR2, MSI_KIT_TYPE, p_MSI_KIT_TYPE)
			, MSI_KIT_PRINCIPAL_FLAG = DECODE(p_MSI_KIT_PRINCIPAL_FLAG, FT_COMMON.G_MISS_VARCHAR2, MSI_KIT_PRINCIPAL_FLAG, p_MSI_KIT_PRINCIPAL_FLAG)
			, MSI_KIT_PARENT = DECODE(p_MSI_KIT_PARENT, FT_COMMON.G_MISS_VARCHAR2, MSI_KIT_PARENT, p_MSI_KIT_PARENT)
			, MSI_ASSET_BADGEABLE_FLAG = DECODE(p_MSI_ASSET_BADGEABLE_FLAG, FT_COMMON.G_MISS_VARCHAR2, MSI_ASSET_BADGEABLE_FLAG, p_MSI_ASSET_BADGEABLE_FLAG)
			, MSI_ASSET_SERIABLE_FLAG = DECODE(p_MSI_ASSET_SERIABLE_FLAG, FT_COMMON.G_MISS_VARCHAR2, MSI_ASSET_SERIABLE_FLAG, p_MSI_ASSET_SERIABLE_FLAG)
