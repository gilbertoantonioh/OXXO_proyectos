			, p_RCV_PO_RELEASE_ID IN NUMBER DEFAULT FT_COMMON.G_MISS_NUMBER
			, p_RCV_PO_LINE_ID IN NUMBER DEFAULT FT_COMMON.G_MISS_NUMBER
			, p_POL_PO_LINE_NUM IN NUMBER DEFAULT FT_COMMON.G_MISS_NUMBER
			, p_RCV_PO_LINE_LOCATION_ID IN NUMBER DEFAULT FT_COMMON.G_MISS_NUMBER
			, p_RCV_QUANTITY IN NUMBER DEFAULT FT_COMMON.G_MISS_NUMBER
			, p_RCV_PO_UNIT_PRICE IN NUMBER DEFAULT FT_COMMON.G_MISS_NUMBER
			, p_RCV_CURRENCY_CODE IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_RCV_CURRENCY_CONVERSION_RATE IN NUMBER DEFAULT FT_COMMON.G_MISS_NUMBER
			, p_RCV_CURRENCY_CONVERSION_DATE IN DATE DEFAULT FT_COMMON.G_MISS_DATE
