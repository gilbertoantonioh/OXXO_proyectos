			, p_MSI_ASSET_BADGEABLE_FLAG IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
			, p_MSI_ASSET_SERIABLE_FLAG IN VARCHAR2 DEFAULT FT_COMMON.G_MISS_VARCHAR2
