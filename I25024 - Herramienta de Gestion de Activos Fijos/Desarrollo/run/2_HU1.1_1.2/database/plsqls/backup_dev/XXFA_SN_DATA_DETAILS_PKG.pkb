			, ASS_VENDOR_SITE_CODE
			, RCV_INV_ORGANIZATION_ID
			, MTL_INV_ORGANIZATION_CODE
			, POH_ORG_ID
			, HOU_ORG_CODE
			, FAA_ASSET_ID
			, FAA_ASSET_NUMBER
			, FAA_TAG_NUMBER
			, FAA_ASSET_CATEGORY_ID
