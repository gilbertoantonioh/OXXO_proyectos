			, p_MSI_KIT_PRINCIPAL_FLAG IN VARCHAR2
			, p_MSI_KIT_PARENT IN VARCHAR2
			, p_MSI_ASSET_BADGEABLE_FLAG IN VARCHAR2
			, p_MSI_ASSET_SERIABLE_FLAG IN VARCHAR2
